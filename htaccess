# =============================================
# ARKEDIA 3D — .htaccess
# =============================================

RewriteEngine On

# 1. Forcer HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 2. Forcer www (canonique unique)
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule ^ https://www.%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# =============================================
# COMPRESSION GZIP — réduit le poids des fichiers
# =============================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# =============================================
# CACHE NAVIGATEUR — accélère les visites répétées
# =============================================
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png "access plus 3 months"
    ExpiresByType image/jpeg "access plus 3 months"
    ExpiresByType image/webp "access plus 3 months"
    ExpiresByType image/svg+xml "access plus 3 months"
    ExpiresByType video/mp4 "access plus 6 months"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# =============================================
# SÉCURITÉ — headers de base
# =============================================
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
